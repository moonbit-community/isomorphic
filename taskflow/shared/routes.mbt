///|
/// `POST` ‚Äî register a new user.
pub let api_register : String = "/api/auth/register"

///|
/// `POST` ‚Äî log in with username and password.
pub let api_login : String = "/api/auth/login"

///|
/// `POST` ‚Äî log out (clear session cookie).
pub let api_logout : String = "/api/auth/logout"

///|
/// `GET` ‚Äî get the current logged-in user from session cookie.
pub let api_me : String = "/api/auth/me"

///|
/// `GET` ‚Äî fetch the full board (tasks + members + today).
pub let api_board : String = "/api/board"

///|
/// `POST` ‚Äî create a new task.
pub let api_tasks : String = "/api/tasks"

///|
/// `POST` to update, `DELETE` to remove a task.
pub fn api_task(id : Int) -> String {
  "/api/tasks/\{id}"
}

///|
/// `POST` ‚Äî change a task's status.
pub fn api_task_status(id : Int) -> String {
  "/api/tasks/\{id}/status"
}

///|
/// `GET` ‚Äî list comments for a task. `POST` ‚Äî add a comment.
pub fn api_task_comments(id : Int) -> String {
  "/api/tasks/\{id}/comments"
}

///|
/// `GET` ‚Äî list dependencies for a task. `POST` ‚Äî add a dependency.
pub fn api_task_deps(id : Int) -> String {
  "/api/tasks/\{id}/deps"
}

///|
/// `POST` ‚Äî remove a dependency.
pub fn api_task_deps_remove(id : Int) -> String {
  "/api/tasks/\{id}/deps/remove"
}

///|
/// `GET` ‚Äî list all team members.
pub let api_members : String = "/api/members"

///|
/// `GET` ‚Äî export all tasks as JSON.
pub let api_export : String = "/api/export"

///|
/// `GET` ‚Äî list all labels. `POST` ‚Äî create a label.
pub let api_labels : String = "/api/labels"

///|
/// `GET` ‚Äî list labels for a task. `POST` ‚Äî add a label to a task.
pub fn api_task_labels(id : Int) -> String {
  "/api/tasks/\{id}/labels"
}

///|
/// `POST` ‚Äî remove a label from a task.
pub fn api_task_labels_remove(id : Int) -> String {
  "/api/tasks/\{id}/labels/remove"
}

///|
/// `GET` ‚Äî list subtasks for a task. `POST` ‚Äî add a subtask.
pub fn api_task_subtasks(id : Int) -> String {
  "/api/tasks/\{id}/subtasks"
}

///|
/// `POST` ‚Äî toggle a subtask's done state.
pub fn api_subtask_toggle(id : Int) -> String {
  "/api/subtasks/\{id}/toggle"
}

///|
/// `DELETE` ‚Äî remove a subtask.
pub fn api_subtask(id : Int) -> String {
  "/api/subtasks/\{id}"
}

///|
/// `GET` ‚Äî list time entries for a task. `POST` ‚Äî log time.
pub fn api_task_time(id : Int) -> String {
  "/api/tasks/\{id}/time"
}

///|
/// `DELETE` ‚Äî remove a time entry.
pub fn api_time_entry(id : Int) -> String {
  "/api/time/\{id}"
}

///|
/// `POST` ‚Äî set recurrence for a task. `DELETE` ‚Äî remove recurrence.
pub fn api_task_recurrence(id : Int) -> String {
  "/api/tasks/\{id}/recurrence"
}
