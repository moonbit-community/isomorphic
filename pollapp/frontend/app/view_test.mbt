// TODO(upstream): Add `derive(Debug)` to `Html` / `VNode` in rabbita so view
// tests can use `debug_inspect` snapshots (like update tests) instead of
// rendering to HTML strings.
//
// TODO: Write an html beautify/pretty-print function so rendered snapshots are
// human-readable (indented, one-tag-per-line) instead of single-line blobs.
//
// TODO(upstream): `App::with_init` missing `#cfg(target="js")` blocks native
// SSR — see https://github.com/moonbit-community/rabbita/issues/110
// Once fixed, `render_to_string(static_cell(html))` works on native target,
// enabling server-side rendering from the backend. The Html DSL, Cell,
// static_cell, and render_to_string are all already target-agnostic.
// To do native SSR:
//   1. Patch or wait for rabbita fix (one-line `#cfg` guard)
//   2. Change frontend/app `supported_targets` from "js" to "all"
//   3. Guard `update.mbt` HTTP imports with `#cfg(target="js")`
//   4. Backend imports frontend/app, calls `model.view(noop_dispatch)`
//   5. Use `render_to_string(static_cell(html))` to produce the HTML string
//   6. Inject into the HTML shell instead of empty `<div id="app"></div>`

///|
/// Render an `Html` node to its HTML string representation for test assertions.
#warnings("-alert_unstable")
fn render(html : @rabbita.Html) -> String {
  @rabbita.render_to_string(@rabbita.static_cell(html))
}

// ── Full view ───────────────────────────────────────────────────────

///|
test "view shows empty state with no polls" {
  inspect(
    render(empty_model().view(noop_dispatch)),
    content=(
      #|<div style="max-width: 520px;margin: 0 auto;padding: 24px 16px;font-family: -apple-system, BlinkMacSystemFont, &#39;Segoe UI&#39;, Roboto, sans-serif"><div style="text-align: center;margin-bottom: 24px;padding-top: 12px"><h1 style="color: white;font-size: 26px;font-weight: 800;margin-bottom: 4px;letter-spacing: -0.5px">Poll App</h1><p style="color: rgba(255,255,255,0.75);font-size: 13px">Create polls and vote</p></div><div style="background: white;border-radius: 14px;padding: 18px 20px;margin-bottom: 14px;box-shadow: 0 1px 8px rgba(0,0,0,0.06)"><h2 style="font-size: 13px;font-weight: 700;color: #999;margin-bottom: 14px;text-transform: uppercase;letter-spacing: 0.5px">Create Poll</h2><form style="display: flex;flex-direction: column;gap: 10px"><input type="text" autocomplete="off" placeholder="What&#39;s your question?" style="padding: 10px 14px;border: 2px solid #eee;border-radius: 10px;font-size: 14px;outline: none" value=""></input><div style="font-size: 12px;font-weight: 700;color: #999;text-transform: uppercase;letter-spacing: 0.5px;margin-top: 4px">Options</div><div style="display: flex;gap: 8px;align-items: center"><input type="text" autocomplete="off" placeholder="Option 1" style="flex: 1;padding: 10px 14px;border: 2px solid #eee;border-radius: 10px;font-size: 14px;outline: none" value=""></input><span></span></div><div style="display: flex;gap: 8px;align-items: center"><input type="text" autocomplete="off" placeholder="Option 2" style="flex: 1;padding: 10px 14px;border: 2px solid #eee;border-radius: 10px;font-size: 14px;outline: none" value=""></input><span></span></div><button type="button" style="padding: 8px;background: #f0f0ff;color: #667eea;border: 2px dashed #ccc;border-radius: 10px;cursor: pointer;font-size: 13px;font-weight: 600">+ Add Option</button><button type="submit" style="padding: 12px;background: linear-gradient(135deg, #667eea, #764ba2);color: white;border: none;border-radius: 10px;cursor: pointer;font-size: 15px;font-weight: 600;margin-top: 2px">Create Poll</button></form></div><div style="background: white;border-radius: 14px;padding: 18px 20px;margin-bottom: 14px;box-shadow: 0 1px 8px rgba(0,0,0,0.06)"><h2 style="font-size: 13px;font-weight: 700;color: #999;margin-bottom: 14px;text-transform: uppercase;letter-spacing: 0.5px">Polls</h2><p style="color: #aaa;font-size: 13px;text-align: center;padding: 12px 0">No polls yet. Create one above!</p></div></div>
    ),
  )
}

///|
test "view renders poll cards" {
  let model = { ..empty_model(), polls: [sample_poll()] }
  inspect(
    render(model.view(noop_dispatch)),
    content=(
      #|<div style="max-width: 520px;margin: 0 auto;padding: 24px 16px;font-family: -apple-system, BlinkMacSystemFont, &#39;Segoe UI&#39;, Roboto, sans-serif"><div style="text-align: center;margin-bottom: 24px;padding-top: 12px"><h1 style="color: white;font-size: 26px;font-weight: 800;margin-bottom: 4px;letter-spacing: -0.5px">Poll App</h1><p style="color: rgba(255,255,255,0.75);font-size: 13px">Create polls and vote</p></div><div style="background: white;border-radius: 14px;padding: 18px 20px;margin-bottom: 14px;box-shadow: 0 1px 8px rgba(0,0,0,0.06)"><h2 style="font-size: 13px;font-weight: 700;color: #999;margin-bottom: 14px;text-transform: uppercase;letter-spacing: 0.5px">Create Poll</h2><form style="display: flex;flex-direction: column;gap: 10px"><input type="text" autocomplete="off" placeholder="What&#39;s your question?" style="padding: 10px 14px;border: 2px solid #eee;border-radius: 10px;font-size: 14px;outline: none" value=""></input><div style="font-size: 12px;font-weight: 700;color: #999;text-transform: uppercase;letter-spacing: 0.5px;margin-top: 4px">Options</div><div style="display: flex;gap: 8px;align-items: center"><input type="text" autocomplete="off" placeholder="Option 1" style="flex: 1;padding: 10px 14px;border: 2px solid #eee;border-radius: 10px;font-size: 14px;outline: none" value=""></input><span></span></div><div style="display: flex;gap: 8px;align-items: center"><input type="text" autocomplete="off" placeholder="Option 2" style="flex: 1;padding: 10px 14px;border: 2px solid #eee;border-radius: 10px;font-size: 14px;outline: none" value=""></input><span></span></div><button type="button" style="padding: 8px;background: #f0f0ff;color: #667eea;border: 2px dashed #ccc;border-radius: 10px;cursor: pointer;font-size: 13px;font-weight: 600">+ Add Option</button><button type="submit" style="padding: 12px;background: linear-gradient(135deg, #667eea, #764ba2);color: white;border: none;border-radius: 10px;cursor: pointer;font-size: 15px;font-weight: 600;margin-top: 2px">Create Poll</button></form></div><div style="background: white;border-radius: 14px;padding: 18px 20px;margin-bottom: 14px;box-shadow: 0 1px 8px rgba(0,0,0,0.06)"><div style="display: flex;justify-content: space-between;align-items: flex-start;margin-bottom: 14px"><h3 style="font-size: 16px;font-weight: 700;color: #333;flex: 1">Favorite color?</h3><button style="width: 28px;height: 28px;background: #fee;color: #e53935;border: none;border-radius: 8px;cursor: pointer;font-size: 13px;font-weight: 700;flex-shrink: 0;display: flex;align-items: center;justify-content: center;margin-left: 12px">X</button></div><div style="position: relative;padding: 12px 14px;border-radius: 10px;background: #f5f5f8;overflow: hidden;margin-bottom: 6px;cursor: pointer;transition: background 0.2s ease"><span style="font-size: 14px;font-weight: 500;color: #333">Red</span></div><div style="position: relative;padding: 12px 14px;border-radius: 10px;background: #f5f5f8;overflow: hidden;margin-bottom: 6px;cursor: pointer;transition: background 0.2s ease"><span style="font-size: 14px;font-weight: 500;color: #333">Blue</span></div><div style="font-size: 12px;color: #999;margin-top: 8px;text-align: right">8 total votes</div></div></div>
    ),
  )
}

